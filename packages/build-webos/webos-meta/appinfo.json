{
    "id": "org.moonfinplus.webos",
    "version": "2.3.1",
    "vendor": "moonfin+",
    "type": "web",
    "main": "index.html",
    "title": "moonfin+",
    "appDescription": "Jellyfin media client for LG webOS TV",
    "icon": "icon-80.png",
    "largeIcon": "icon-130.png",
    "bgImage": "splash.png",
    "splashBackground": "splash.png",
    "bgColor": "#000b25",
    "iconColor": "#000b25",
    "disableBackHistoryAPI": true,
    "requiredPermissions": [
        "time.query",
